/**
 * パターン1: doGet用の軽量承認待ちカウント
 * 経費明細(EXPENSES)・経費項目マスタを読まないため doGet が大幅に高速化される
 */
function getPendingCount_() {
  try {
    var userInfo = getCachedUserInfo_();
    var myId = userInfo.employeeInfo.id;
    var reports = getSheetData_(SHEET_NAMES.REPORTS);
    var employees = getSheetData_(SHEET_NAMES.EMPLOYEES);
    var approverMap = {};
    employees.forEach(function(e) {
      approverMap[e['社員番号']] = { app1: e['承認者番号1'], app2: e['承認者番号2'] };
    });
    return reports.filter(function(row) {
      var status = row['承認ステータス'];
      var applicantId = row['申請者社員番号'];
      var settings = approverMap[applicantId];
      if (!settings) return false;
      if (status === '1次承認待ち') return String(settings.app1) === String(myId);
      if (status === '2次承認待ち') return String(settings.app2) === String(myId);
      return false;
    }).length;
  } catch(e) { return 0; }
}

/**
 * ⑧ マスタキャッシュ強制クリア用関数
 * スプレッドシートのマスタシートを更新したあと、
 * GASエディタからこの関数を実行するとすぐにアプリに反映される。
 */
