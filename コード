function doGet(e) {
  var ui = HtmlService.createTemplateFromFile('index.html');

  // ⑧ ユーザー情報はユーザー単位キャッシュ（10分）
  var userInfo = getCachedUserInfo_();
  // ⑧ マスタデータはスクリプトキャッシュ（1時間）、経費項目マスタは1回だけ読み込み
  var masterData = getCachedMasterData_();

  ui.employeeInfo = JSON.stringify(userInfo.employeeInfo);
  ui.isManager = userInfo.isManager;
  ui.isAccountingAdmin = userInfo.isAccountingAdmin;
  ui.expenseItems = JSON.stringify(masterData.expenseItems);
  ui.travelRules = JSON.stringify(masterData.travelRules);
  ui.areaMaster = JSON.stringify(masterData.areaMaster);
  ui.taxMaster = JSON.stringify(masterData.taxMaster);
  ui.expenseItemPatterns = JSON.stringify(masterData.expenseItemPatterns);

  var pendingCount = 0;
  if (userInfo.isManager) {
    // パターン1: EXPENSESシートを読まない軽量カウント専用関数で高速化
    pendingCount = getPendingCount_();
  }
  ui.pendingCount = pendingCount;

  var unclaimedCount = 0;
  if (userInfo.employeeInfo.hasCard) {
    var unclaimed = getUnclaimedCardTransactions().data || [];
    unclaimedCount = unclaimed.length;
  }
  ui.unclaimedCount = unclaimedCount;

  return ui.evaluate()
    .setTitle('経費精算アプリ')
    .addMetaTag('viewport', 'width=device-width, initial-scale=1');
}

/**
 * ⑧ マスタデータをスクリプトキャッシュから取得（なければシートから読込・キャッシュ保存）
 * 経費項目マスタは①②③の用途すべてで兼用するため1回だけ読み込む
 */
function getCachedMasterData_() {
  var cache = CacheService.getScriptCache();
  var CACHE_KEY = 'MASTER_DATA_V2';
  var cached = cache.get(CACHE_KEY);
  if (cached) {
    try { return JSON.parse(cached); } catch(e) {}
  }

  // キャッシュなし → シートから一括読み込み
  var expenseItems = getSheetData_(SHEET_NAMES.EXPENSE_ITEMS);
  var masterData = {
    expenseItems: expenseItems,
    travelRules: getSheetData_(SHEET_NAMES.TRAVEL_RULES),
    areaMaster: getSheetData_(SHEET_NAMES.AREA_MASTER),
    taxMaster: getSheetData_(SHEET_NAMES.TAX_MASTER),
    expenseItemPatterns: getSheetData_(SHEET_NAMES.EXPENSE_ITEM_PATTERNS)
  };

  // ⑧ サイズ上限（100KB）超過時はキャッシュに保存しない
  try {
    cache.put(CACHE_KEY, JSON.stringify(masterData), 3600);
  } catch(e) {
    Logger.log('マスタキャッシュ保存失敗（サイズ超過の可能性）: ' + e);
  }
  return masterData;
}

/**
 * ⑧ ユーザー情報をユーザー単位キャッシュから取得（なければ読込・10分キャッシュ）
 */
function getCachedUserInfo_() {
  var email = Session.getActiveUser().getEmail();
  var cache = CacheService.getUserCache();
  var CACHE_KEY = 'USER_INFO_' + email;
  var cached = cache.get(CACHE_KEY);
  if (cached) {
    try { return JSON.parse(cached); } catch(e) {}
  }

  var userInfo = getUserInfo_();
  try {
    cache.put(CACHE_KEY, JSON.stringify(userInfo), 600);
  } catch(e) {
    Logger.log('ユーザー情報キャッシュ保存失敗: ' + e);
  }
  return userInfo;
}

/**
 * 社員マスタ全件をスクリプトキャッシュから取得（10分）
