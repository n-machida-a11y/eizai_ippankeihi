function searchReports(criteria) {
  try {
    var allData = getMyReports();
    
    var searchStart = criteria.startDate ? criteria.startDate.replace(/-/g, '/') : null;
    var searchEnd = criteria.endDate ? criteria.endDate.replace(/-/g, '/') : null;

    var filtered = allData.filter(function(r) {
      var reportDate = r['日付']; 
      if (searchStart && reportDate < searchStart) return false;
      if (searchEnd && reportDate > searchEnd) return false;
      
      var amt = Number(String(r['合計経費']).replace(/,/g, ''));
      var min = criteria.minAmount ? Number(criteria.minAmount) : null;
      var max = criteria.maxAmount ? Number(criteria.maxAmount) : null;

      if (min !== null && amt < min) return false;
      if (max !== null && amt > max) return false;
      
      if (criteria.payee) {
        var term = criteria.payee.toLowerCase();
        var headerMatch = (r['件名'] && r['件名'].toLowerCase().indexOf(term) > -1) ||
                          (r['備考'] && r['備考'].toLowerCase().indexOf(term) > -1);
        var detailsMatch = r.details.some(function(d) {
          var p = (d.payee || '').toLowerCase();
          var rm = (d.remarks || '').toLowerCase();
          return p.indexOf(term) > -1 || rm.indexOf(term) > -1;
        });
        if (!headerMatch && !detailsMatch) return false;
      }
      return true;
    });
    return filtered;
  } catch(e) {
    Logger.log('Search Error: ' + e);
    throw e;
  }
}

function getMyReports() {
  try {
    // キャッシュチェック（保存・削除時にクリアされるため整合性を維持）
    var cachedResult = getCachedMyReports_();
    if (cachedResult) return cachedResult;

    var userInfo = getCachedUserInfo_();
    var targetEmployeeId = userInfo.employeeInfo.id;
    var allData = getSheetData_(SHEET_NAMES.REPORTS);
    var allExpenses = getSheetData_(SHEET_NAMES.EXPENSES);
    // パターン4: 経費項目マスタをキャッシュから取得
    var expenseItemsMaster = getCachedMasterData_().expenseItems;

    var itemMap = {}; expenseItemsMaster.forEach(function(i){ itemMap[i['経費項目コード']] = i['経費項目']; });
    
    var expensesByReportId = {};
    allExpenses.forEach(function(exp) {
      var rId = exp['経費ID'];
      if (!expensesByReportId[rId]) expensesByReportId[rId] = [];
      
      expensesByReportId[rId].push({
        itemName: itemMap[exp['経費項目コード']] || exp['経費項目コード'],
        amount: exp['金額'],
        formattedAmount: Number(exp['金額']).toLocaleString(),
        receiptUrl: exp['領収書URL'],
        payee: exp['支払先'],
        useDate: exp['利用日'],
        remarks: exp['備考'],
        settlementMethod: exp['精算方法'] 
      });
    });

    var myReports = [];
    for (var i = 0; i < allData.length; i++) {
      if (String(allData[i]['申請者社員番号']) === String(targetEmployeeId)) {
        var rId = allData[i]['経費ID'];
        myReports.push({
          '経費ID': rId, '日付': allData[i]['日付'], '件名': allData[i]['件名'],
          '承認ステータス': allData[i]['承認ステータス'], '合計経費': allData[i]['合計経費'],
          'formattedTotal': Number(allData[i]['合計経費']).toLocaleString(),
          '備考': allData[i]['備考'], 
          'details': expensesByReportId[rId] || []
        });
      }
    }
    var statusOrder = { '一時保存': 1, '差戻し': 2, '申請中': 3, '1次承認待ち': 4, '2次承認待ち': 5, '承認済': 6, '精算申請済': 7 };
    myReports.sort(function(a,b){
      var sa = statusOrder[a['承認ステータス']]||99, sb = statusOrder[b['承認ステータス']]||99;
      if(sa !== sb) return sa - sb;
      return (b['日付']||'').localeCompare(a['日付']||'');
    });

    // キャッシュ保存（次回の申請一覧表示を高速化）
    setCachedMyReports_(myReports);
    return myReports;
  } catch (e) { throw e; }
}

function getReportDataForEdit(reportId) {
  try {
    var userInfo = getCachedUserInfo_();
    var userId = userInfo.employeeInfo.id;
    var details = getReportDetails(reportId);
    
    if (!details.header || !details.header['経費ID']) return { status: "error", message: "対象の申請データが見つかりません。" };
    if (String(details.header['申請者社員番号']) !== String(userId)) return { status: "error", message: "この申請を編集する権限がありません。" };
    
    var status = details.header['承認ステータス'];
    if (status !== '一時保存' && status !== '差戻し') return { status: "error", message: "「" + status + "」の申請は編集できません。" };
    
    return { status: "success", data: details };
  } catch (e) {
    Logger.log('getReportDataForEdit エラー: ' + e);
    return { status: "error", message: "編集データの読み込みエラー: " + e.message };
  }
}

function getSheetData_(sheetName) {
  var idToUse = (sheetName.indexOf('マスタ') > -1 || sheetName === SHEET_NAMES.EXPENSE_ITEM_PATTERNS) ? MASTER_SPREADSHEET_ID : DATA_SPREADSHEET_ID;
  if (!idToUse) return [];
  var ss = SpreadsheetApp.openById(idToUse);
  var sheet = ss.getSheetByName(sheetName);
  if (!sheet || sheet.getLastRow() < 2) return [];
  var data = sheet.getRange(1, 1, sheet.getLastRow(), sheet.getLastColumn()).getValues();
  var headers = data.shift();
  return data.map(function(row) {
    var obj = {};
    headers.forEach(function(h, i) {
      if (row[i] instanceof Date) obj[h] = Utilities.formatDate(row[i], Session.getScriptTimeZone(), 'yyyy/MM/dd');
      else obj[h] = row[i];
    });
    return obj;
  });
}

function updateReportStatus_(reportId, newStatus, rejectionReason) {
  var ss = SpreadsheetApp.openById(DATA_SPREADSHEET_ID);
  var sheet = ss.getSheetByName(SHEET_NAMES.REPORTS);
  var data = sheet.getDataRange().getValues();
  var idxId = data[0].indexOf('経費ID');
  var idxStatus = data[0].indexOf('承認ステータス');
  var idxReason = data[0].indexOf('差戻し理由');
  
  for(var i=1; i<data.length; i++) {
    if(String(data[i][idxId]) === String(reportId)) {
      sheet.getRange(i+1, idxStatus+1).setValue(newStatus);
      if(newStatus === '差戻し' && idxReason > -1) sheet.getRange(i+1, idxReason+1).setValue(rejectionReason);
      return { status: "success", message: "更新しました" };
    }
  }
  throw new Error("更新対象が見つかりません");
}

function deleteReportData_(reportId, ss) {
  var cSheet = ss.getSheetByName(SHEET_NAMES.CARD_TRANSACTIONS);
  if(cSheet) {
    var cData = cSheet.getDataRange().getValues();
    var idxCStatus = cData[0].indexOf('ステータス'), idxCRep = cData[0].indexOf('紐付いた経費ID');
    for(var i=1; i<cData.length; i++) {
      if(String(cData[i][idxCRep]) === String(reportId)) {
        cSheet.getRange(i+1, idxCStatus+1).setValue('未精算');
        cSheet.getRange(i+1, idxCRep+1).setValue('');
      }
    }
  }
  [SHEET_NAMES.REPORTS, SHEET_NAMES.EXPENSES].forEach(function(sn){
    var s = ss.getSheetByName(sn);
    if(!s) return;
    var d = s.getDataRange().getValues();
    var idx = d[0].indexOf('経費ID');
    if(idx === -1) idx = d[0].indexOf('日報ID');
    var rows = [];
    for(var i=1; i<d.length; i++) if(String(d[i][idx])===String(reportId)) rows.push(i+1);
    rows.sort(function(a,b){return b-a;});
    rows.forEach(function(r){ s.deleteRow(r); });
  });
}
