function saveOrSubmitExpenseReport(data, action) {
  var lock = LockService.getScriptLock();
  lock.waitLock(15000);
  var ss = SpreadsheetApp.openById(DATA_SPREADSHEET_ID);
  var userInfo = getCachedUserInfo_();
  
  try {
    var header = data.header;
    var expenses = data.expenses;
    var reportId = header.reportId;

    if (!reportId) reportId = 'KEIHI-' + Utilities.getUuid();
    
    deleteReportData_(reportId, ss); 
    
    var totalExpenseAmount = 0;
    var allowanceCount = 0;
    var transactionIdsToClaim = [];

    for (var k = 0; k < expenses.length; k++) {
      totalExpenseAmount += parseFloat(expenses[k].amount || 0);
      if (String(expenses[k].itemCode) === '101') allowanceCount++;
      if (expenses[k].transactionId) {
        transactionIdsToClaim.push(expenses[k].transactionId);
      }
      
      if (!expenses[k].itemCode) throw new Error((k+1) + '行目の「経費項目」が未入力です。');
      if (!expenses[k].settlementMethod) throw new Error((k+1) + '行目の「精算方法」が未入力です。');
    }

    if (allowanceCount > 1) throw new Error('日当(101)が複数登録されています。');

    var nextStatus = '一時保存';
    if (action === '申請中') {
      if (userInfo.employeeInfo.approver1Name) {
        nextStatus = '1次承認待ち';
      } else if (userInfo.employeeInfo.approver2Name) {
        nextStatus = '2次承認待ち';
      } else {
        nextStatus = '承認済'; 
      }
    }

    var provisionalPayment = parseFloat(header.provisionalPayment || 0);
    var reimbursementAmount = totalExpenseAmount - provisionalPayment;

    var headerRow = [
      reportId, header.date, userInfo.employeeInfo.name, header.title, header.remarks,
      nextStatus, userInfo.employeeInfo.id, totalExpenseAmount,
      (action === '申請中') ? new Date() : null, null,
      '', '', 0, 
      provisionalPayment, 
      reimbursementAmount 
    ];
    
    var hSheet = ss.getSheetByName(SHEET_NAMES.REPORTS);
    var hHeaders = [];
    if (hSheet.getLastRow() >= 1) {
        hHeaders = hSheet.getRange(1, 1, 1, hSheet.getLastColumn()).getValues()[0];
    }
    if (hHeaders.indexOf('仮払金') === -1) hSheet.getRange(1, 14).setValue("仮払金");
    if (hHeaders.indexOf('差引精算額') === -1) hSheet.getRange(1, 15).setValue("差引精算額");
    
    hSheet.appendRow(headerRow);

    // パターン4: 消費税マスタをキャッシュから取得
    var taxMaster = getCachedMasterData_().taxMaster;
    var taxMap = {};
    taxMaster.forEach(function(t) {
      taxMap[t['消費税区分コード']] = t['消費税区分']; // コード → 名称
    });

    var expSheet = ss.getSheetByName(SHEET_NAMES.EXPENSES);
    var expensesRows = expenses.map(function(exp) {
      var expenseId = exp.expenseId;
      if (!expenseId || expenseId.startsWith('temp_')) expenseId = 'EXP-' + Utilities.getUuid();
      
      // 消費税区分コードから消費税区分名を取得
      var taxDistName = taxMap[exp.taxDistCode] || '';
      
      return [
        reportId,                          // 1: 経費ID
        expenseId,                         // 2: 明細ID
        exp.itemCode || '',                // 3: 経費項目コード
        exp.amount,                        // 4: 金額
        exp.receiptUrl,                    // 5: 領収書URL
        exp.remarks,                       // 6: 備考
        exp.useDate,                       // 7: 利用日
        exp.areaCode || null,              // 8: エリアコード
        taxDistName,                       // 9: 消費税区分（名称）
        exp.preTaxAmount,                  // 10: 税抜金額
        exp.payee || '',                   // 11: 支払先
        exp.isCard ? '有' : '無',          // 12: カード利用
        exp.cardUsageAmount || 0,          // 13: カード利用額
        exp.transactionId || '',           // 14: トランザクションID
        exp.settlementMethod || '',        // 15: 精算方法
        exp.taxRate || 10,                 // 16: 消費税率
        exp.taxClass || '',                // 17: 消費税分類区分
        exp.taxCalc || ''                  // 18: 消費税計算区分
      ];
    });
    
    if (expensesRows.length > 0) {
      var eHeaders = [];
      if (expSheet.getLastRow() >= 1) {
          eHeaders = expSheet.getRange(1, 1, 1, expSheet.getLastColumn()).getValues()[0];
      }
      // ヘッダー名の設定
      if (eHeaders.indexOf('消費税区分') === -1 || eHeaders.indexOf('消費税率') === -1) {
          expSheet.getRange(1, 9).setValue("消費税区分");
          expSheet.getRange(1, 16).setValue("消費税率");
          expSheet.getRange(1, 17).setValue("消費税分類区分");
          expSheet.getRange(1, 18).setValue("消費税計算区分");
      }

      expSheet.getRange(expSheet.getLastRow() + 1, 1, expensesRows.length, expensesRows[0].length).setValues(expensesRows);
    }
    
    if (transactionIdsToClaim.length > 0) {
      updateCardTransactionStatus_(transactionIdsToClaim, '精算中', reportId, ss);
    }
    
    if (action === '申請中') {
      sendApprovalEmail_(userInfo.employeeInfo, nextStatus, header, totalExpenseAmount);
    }

    // 申請一覧キャッシュを無効化（次回取得時に最新データを読む）
    clearMyReportsCache_();
    return { status: "success", message: nextStatus + "へステータスを更新しました。", reportId: reportId };
  } catch (e) {
    Logger.log('saveOrSubmitExpenseReport エラー: ' + e);
    return { status: "error", message: "保存中にエラーが発生しました: " + e.message };
  } finally {
    lock.releaseLock();
  }
}

function sendApprovalEmail_(applicantInfo, status, header, amount) {
  var employees = getCachedEmployees_();
  var targetEmail = null;
  var subject = '';
  
  if (status === '1次承認待ち') {
    var approver = employees.find(function(e) { return String(e['社員番号']) === String(applicantInfo.approver1Id); });
    if (approver) targetEmail = approver['アドレス'];
    subject = '[経費精算] 1次承認依頼: ' + applicantInfo.name;
  } else if (status === '2次承認待ち') {
    var approver = employees.find(function(e) { return String(e['社員番号']) === String(applicantInfo.approver2Id); });
    if (approver) targetEmail = approver['アドレス'];
    subject = '[経費精算] 2次承認依頼: ' + applicantInfo.name;
  } else if (status === '承認済') {
    var settings = getSettings_();
    targetEmail = settings.ACCOUNTING_EMAIL;
    subject = '[経費精算] 承認・連携通知: ' + applicantInfo.name;
  }

  if (targetEmail) {
    GmailApp.sendEmail(
      targetEmail,
      subject,
      applicantInfo.name + ' さんから経費精算の依頼/通知が届きました。\n\n' +
      '日付: ' + header.date + '\n' +
      '件名: ' + header.title + '\n' +
      '合計経費: ' + amount + ' 円\n\n' +
      'システムより確認してください。\n' + ScriptApp.getService().getUrl()
    );
  }
}

function uploadBase64Image(base64Data, originalFileName) {
  try {
    var folderId = "1VQgPXronOxngn40uiUVK2eRUPTWSWS4I"; // 本番フォルダID
    
    var now = new Date();
    var timestamp = Utilities.formatDate(now, Session.getScriptTimeZone(), 'yyyyMMdd_HHmmss');
    var fileName = timestamp + '_' + (originalFileName || 'receipt');
    
    var mimeType = 'application/octet-stream';
    var base64Parts = base64Data.split(',');
    if (base64Parts[0].indexOf('application/pdf') > -1) {
      mimeType = 'application/pdf';
    } else if (base64Parts[0].indexOf('image/jpeg') > -1) {
      mimeType = 'image/jpeg';
    } else if (base64Parts[0].indexOf('image/png') > -1) {
      mimeType = 'image/png';
    } else if (base64Parts[0].indexOf('image/gif') > -1) {
      mimeType = 'image/gif';
    } else if (base64Parts[0].indexOf('image/webp') > -1) {
      mimeType = 'image/webp';
    }
    
    var blob = Utilities.newBlob(Utilities.base64Decode(base64Parts[1]), mimeType, fileName);
    var folder = DriveApp.getFolderById(folderId);
    var file = folder.createFile(blob);
    file.setSharing(DriveApp.Access.DOMAIN_WITH_LINK, DriveApp.Permission.VIEW);
    
    return { status: "success", url: file.getUrl() };
  } catch (e) {
    Logger.log('uploadBase64Image エラー: ' + e);
    return { status: "error", message: "ファイルアップロードエラー: " + e.message };
  }
}

function withdrawReport(reportId) {
  var lock = LockService.getScriptLock();
  lock.waitLock(15000);
  try {
    var userInfo = getCachedUserInfo_();
    var userId = userInfo.employeeInfo.id;
    var ss = SpreadsheetApp.openById(DATA_SPREADSHEET_ID);
    var sheet = ss.getSheetByName(SHEET_NAMES.REPORTS);
    
    var data = sheet.getRange(1, 1, sheet.getLastRow(), sheet.getLastColumn()).getValues();
    var headers = data[0];
    var reportIdCol = headers.indexOf('経費ID');
    var statusCol = headers.indexOf('承認ステータス');
    var applicantIdCol = headers.indexOf('申請者社員番号');
    
    for (var i = 1; i < data.length; i++) {
      if (String(data[i][reportIdCol]) === String(reportId)) {
        if (String(data[i][applicantIdCol]) !== String(userId)) throw new Error('権限がありません。');
        var s = data[i][statusCol];
        if (s !== '1次承認待ち' && s !== '2次承認待ち' && s !== '申請中') throw new Error('このステータスは取り下げできません。');
        
        sheet.getRange(i + 1, statusCol + 1).setValue('一時保存');
        clearMyReportsCache_();
        return { status: "success", message: "申請を取り下げ、「一時保存」に戻しました。" };
      }
    }
    throw new Error('データが見つかりません。');
  } catch(e) {
    return { status: "error", message: e.message };
  } finally {
    lock.releaseLock();
  }
}

function deleteReport(reportId) {
  var lock = LockService.getScriptLock();
  lock.waitLock(15000);
  try {
    var userInfo = getCachedUserInfo_();
    var userId = userInfo.employeeInfo.id;
    var ss = SpreadsheetApp.openById(DATA_SPREADSHEET_ID);
    var sheet = ss.getSheetByName(SHEET_NAMES.REPORTS);
    
    var data = sheet.getRange(1, 1, sheet.getLastRow(), sheet.getLastColumn()).getValues();
    var headers = data[0];
    var reportIdCol = headers.indexOf('経費ID');
    var statusCol = headers.indexOf('承認ステータス');
    var applicantIdCol = headers.indexOf('申請者社員番号');
    
    for (var i = 1; i < data.length; i++) {
      if (String(data[i][reportIdCol]) === String(reportId)) {
        if (String(data[i][applicantIdCol]) !== String(userId)) throw new Error('他人の申請は削除できません。');
        var currentStatus = data[i][statusCol];
        if (currentStatus !== '一時保存' && currentStatus !== '差戻し') {
           throw new Error('「一時保存」または「差戻し」以外のデータは削除できません。');
        }
        
        deleteReportData_(reportId, ss);
        clearMyReportsCache_();
        return { status: "success", message: "申請データを削除しました。" };
      }
    }
    throw new Error('対象の申請が見つかりませんでした。');
  } catch(e) {
    return { status: "error", message: "削除エラー: " + e.message };
  } finally {
    lock.releaseLock();
  }
}


