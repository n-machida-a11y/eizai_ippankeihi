function getPendingReports() {
  // キャッシュチェック（承認・差戻し時にクリアされるため整合性を維持）
  var cachedResult = getCachedPendingReports_();
  if (cachedResult) return cachedResult;

  var userInfo = getCachedUserInfo_();
  var myId = userInfo.employeeInfo.id;

  var reports = getSheetData_(SHEET_NAMES.REPORTS);
  var employees = getCachedEmployees_();
  var allExpenses = getSheetData_(SHEET_NAMES.EXPENSES);
  // パターン4: 経費項目マスタをキャッシュから取得
  var expenseItemsMaster = getCachedMasterData_().expenseItems;
  
  // 経費項目マスタのマップ作成
  var itemMap = {}; 
  expenseItemsMaster.forEach(function(i){ itemMap[i['経費項目コード']] = i['経費項目']; });
  
  // 明細を経費IDごとにグループ化
  var expensesByReportId = {};
  allExpenses.forEach(function(exp) {
    var rId = exp['経費ID'];
    if (!expensesByReportId[rId]) expensesByReportId[rId] = [];
    
    expensesByReportId[rId].push({
      itemName: itemMap[exp['経費項目コード']] || exp['経費項目コード'],
      amount: exp['金額'],
      formattedAmount: Number(exp['金額']).toLocaleString(),
      receiptUrl: exp['領収書URL'],
      payee: exp['支払先'],
      useDate: exp['利用日'],
      remarks: exp['備考'],
      settlementMethod: exp['精算方法'] 
    });
  });
  
  var approverMap = {};
  employees.forEach(function(e) {
    approverMap[e['社員番号']] = {
      app1: e['承認者番号1'],
      app2: e['承認者番号2']
    };
  });

  var myPending = reports.filter(function(row) {
    var status = row['承認ステータス'];
    var applicantId = row['申請者社員番号'];
    var settings = approverMap[applicantId];
    
    if (!settings) return false;
    
    if (status === '1次承認待ち') {
      return String(settings.app1) === String(myId);
    } else if (status === '2次承認待ち') {
      return String(settings.app2) === String(myId);
    }
    return false;
  });
  
  // 明細情報と金額情報を追加して返す
  var result = myPending.map(function(row) {
    var rId = row['経費ID'];
    var total = row['合計経費'] || 0;
    var prov = row['仮払金'] || 0;
    var reimb = row['差引精算額'];
    if (reimb === undefined || reimb === "" || reimb === null) {
      reimb = Number(total) - Number(prov);
    }
    
    return {
      '経費ID': rId,
      '日付': row['日付'],
      '申請者': row['申請者'],
      '件名': row['件名'],
      '承認ステータス': row['承認ステータス'],
      '合計経費': total,
      '仮払金': prov,
      '差引精算額': reimb,
      'formattedTotal': Number(total).toLocaleString(),
      '備考': row['備考'],
      'details': expensesByReportId[rId] || []
    };
  });
  
  // 日付の降順でソート
  result.sort(function(a, b) {
    return (b['日付'] || '').localeCompare(a['日付'] || '');
  });

  // キャッシュ保存（次回の承認待ち一覧表示を高速化）
  setCachedPendingReports_(result);
  return result;
}

function getReportDetails(reportId) {
  try {
    var hData = getSheetData_(SHEET_NAMES.REPORTS);
    var header = hData.find(function(r) { return String(r['経費ID']) === String(reportId); });

    var eData = getSheetData_(SHEET_NAMES.EXPENSES);
    var expenses = eData.filter(function(r) { return String(r['経費ID']) === String(reportId); });

    // パターン4: 経費項目マスタ・消費税マスタをキャッシュから取得（毎回シート読込不要）
    var masterData = getCachedMasterData_();
    var itemMaster = masterData.expenseItems;
    var itemMap = {}; itemMaster.forEach(function(i){ itemMap[i['経費項目コード']] = i['経費項目']; });

    var taxMaster = masterData.taxMaster;
    var taxNameToCode = {};
    taxMaster.forEach(function(t) {
      taxNameToCode[t['消費税区分']] = t['消費税区分コード']; // 名称 → コード
    });

    expenses = expenses.map(function(exp) {
      // 消費税区分名からコードを逆引き
      var taxDistName = exp['消費税区分'] || '';
      var taxDistCode = taxNameToCode[taxDistName] || '';
      
      return {
        expenseId: exp['明細ID'], 
        itemCode: exp['経費項目コード'], 
        amount: exp['金額'],
        receiptUrl: exp['領収書URL'], 
        remarks: exp['備考'], 
        useDate: exp['利用日'],
        itemName: itemMap[exp['経費項目コード']] || exp['経費項目コード'],
        settlementMethod: exp['精算方法'] || '', 
        transactionId: exp['トランザクションID'] || null,
        payee: exp['支払先'], 
        isCard: (exp['カード利用'] === '有'), 
        cardUsageAmount: exp['カード利用額'],
        areaCode: exp['エリアコード'],
        preTaxAmount: exp['税抜金額'],
        // 消費税関連
        taxDistCode: taxDistCode,
        taxDistName: taxDistName,
        taxRate: exp['消費税率'] || 10,
        taxClass: exp['消費税分類区分'] || '',
        taxCalc: exp['消費税計算区分'] || ''
      };
    });
    return { header: header || {}, expenses: expenses };
  } catch (e) {
    Logger.log('getReportDetails エラー: ' + e);
    return { header: {}, expenses: [] };
  }
}

function approveReport(reportId) {
  var lock = LockService.getScriptLock();
  lock.waitLock(15000);
  // パターン3: ロック解放後にpendingListを取得できるよう結果を変数に保持
  var result = null;
  try {
    var ss = SpreadsheetApp.openById(DATA_SPREADSHEET_ID);
    var sheet = ss.getSheetByName(SHEET_NAMES.REPORTS);
    var data = sheet.getDataRange().getValues();
    var idxId = data[0].indexOf('経費ID');
    var idxStatus = data[0].indexOf('承認ステータス');
    var idxApplicant = data[0].indexOf('申請者社員番号');

    var targetRow = -1;
    var currentStatus = '';
    var applicantId = '';

    for(var i=1; i<data.length; i++) {
      if(String(data[i][idxId]) === String(reportId)) {
        targetRow = i+1;
        currentStatus = data[i][idxStatus];
        applicantId = data[i][idxApplicant];
        break;
      }
    }

    if(targetRow === -1) throw new Error('申請が見つかりません');

    var nextStatus = '';
    if (currentStatus === '1次承認待ち') {
      nextStatus = '2次承認待ち';
    } else if (currentStatus === '2次承認待ち') {
      nextStatus = '承認済';
    } else {
      throw new Error('承認可能なステータスではありません');
    }

    sheet.getRange(targetRow, idxStatus+1).setValue(nextStatus);
    sheet.getRange(targetRow, data[0].indexOf('差戻し理由')+1).setValue('');

    var header = { date: data[targetRow-1][data[0].indexOf('日付')], title: data[targetRow-1][data[0].indexOf('件名')] };
    var amount = data[targetRow-1][data[0].indexOf('合計経費')];

    var employees = getCachedEmployees_();
    var applicantData = employees.find(function(e){ return String(e['社員番号']) === String(applicantId); });

    var applicantInfoFull = {
      name: applicantData['社員名'],
      approver1Id: applicantData['承認者番号1'],
      approver2Id: applicantData['承認者番号2']
    };

    sendApprovalEmail_(applicantInfoFull, nextStatus, header, amount);
    result = { status: "success", message: "承認しました。ステータス: " + nextStatus };
  } catch(e) {
    result = { status: "error", message: e.message };
  } finally {
    lock.releaseLock();
  }
  // パターン3: 成功時は承認待ちリストを同時返却してフロント側の再取得コールを削減
  if (result && result.status === "success") {
    try {
      clearPendingReportsCache_(); // キャッシュクリアして最新データを取得
      result.pendingList = getPendingReports();
    } catch(e) {}
  }
  return result;
}

function rejectReport(reportId, reason) {
  // パターン3: 差戻し処理後に承認待ちリストを同時返却してフロント側の再取得コールを削減
  var result = null;
  try {
    result = updateReportStatus_(reportId, '差戻し', reason);
  } catch(e) {
    result = { status: "error", message: e.message };
  }
  if (result && result.status === "success") {
    try {
      clearPendingReportsCache_(); // キャッシュクリアして最新データを取得
      result.pendingList = getPendingReports();
    } catch(e) {}
  }
  return result;
}


