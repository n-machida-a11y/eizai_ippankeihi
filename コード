function updateCardTransactionStatus_(ids, status, reportId, ss) {
  var sheet = ss.getSheetByName(SHEET_NAMES.CARD_TRANSACTIONS);
  var data = sheet.getDataRange().getValues();
  var idxId = data[0].indexOf('トランザクションID');
  var idxSt = data[0].indexOf('ステータス');
  var idxRep = data[0].indexOf('紐付いた経費ID');
  
  for(var i=1; i<data.length; i++) {
    if(ids.indexOf(String(data[i][idxId])) > -1) {
