function processCardExcel(base64Data) {
  var lock = LockService.getScriptLock();
  lock.waitLock(30000);
  var tempFileId = null;
  try {
    var ss = SpreadsheetApp.openById(DATA_SPREADSHEET_ID);
    var sheet = ss.getSheetByName(SHEET_NAMES.CARD_TRANSACTIONS);
    if (!sheet) throw new Error('シートが見つかりません。');
    
    var decoded = Utilities.base64Decode(base64Data.split(',')[1]);
    var blob = Utilities.newBlob(decoded, 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet', 'upload.xlsx');
    var resource = { title: "temp_card_" + new Date().getTime() };
    var tempFile = Drive.Files.insert(resource, blob, { convert: true });
    tempFileId = tempFile.id;
    
    var tempSs = SpreadsheetApp.openById(tempFileId);
    var data = tempSs.getSheets()[0].getDataRange().getValues();
    if (data.length < 2) throw new Error('データなし');
    
    var headers = data[0];
    var idxCardNum = headers.indexOf('カード会員番号');
    var idxDate = headers.indexOf('カード利用日'); if (idxDate===-1) idxDate=headers.indexOf('社内処理日');
    var idxAmount = headers.indexOf('カード利用金額 (貸方)');
    var idxDesc = headers.indexOf('摘要1');
    var idxStoreName = headers.indexOf('加盟店名');
    
    if (idxCardNum === -1 || idxAmount === -1) throw new Error('必須列不足');
    
    var newRows = [];
    var affectedCardNumbers = new Set();
    var now = new Date();
    
    for (var i = 1; i < data.length; i++) {
      var row = data[i];
      if (!row[idxCardNum] || row[idxAmount] === "") continue;
      
      var useDate = row[idxDate];
      if (useDate instanceof Date) useDate = Utilities.formatDate(useDate, Session.getScriptTimeZone(), 'yyyy/MM/dd');
      
      var amount = Number(row[idxAmount]);
      if (isNaN(amount)) amount = parseInt(String(row[idxAmount]).replace(/,/g, ''), 10) || 0;
      
      var transId = Utilities.getUuid();
      var storeName = (idxStoreName > -1) ? (row[idxStoreName] || '') : '';
      newRows.push([transId, row[idxCardNum], useDate, amount, row[idxDesc], '未精算', now, '', storeName]);
      affectedCardNumbers.add(String(row[idxCardNum]));
    }
    
    if (newRows.length > 0) {
      sheet.getRange(sheet.getLastRow() + 1, 1, newRows.length, newRows[0].length).setValues(newRows);
      sendCardImportNotification_(Array.from(affectedCardNumbers));
    }
    return { status: "success", message: newRows.length + "件取込完了" };
  } catch (e) {
    return { status: "error", message: e.message };
  } finally {
    if (tempFileId) try { DriveApp.getFileById(tempFileId).setTrashed(true); } catch(e){}
    lock.releaseLock();
  }
}

function sendCardImportNotification_(cardNumbers) {
  if (cardNumbers.length === 0) return;
  var employees = getSheetData_(SHEET_NAMES.EMPLOYEES);
  var emailMap = {};
  employees.forEach(function(e) { if(e['カード'] && e['アドレス']) emailMap[String(e['カード']).trim()] = e['アドレス']; });
  
  cardNumbers.forEach(function(cn) {
    var email = emailMap[String(cn).trim()];
    if(email) {
      try {
        GmailApp.sendEmail(email, '[経費精算] カード明細取込通知', '未申請のカード明細が取り込まれました。\n確認してください。\n' + ScriptApp.getService().getUrl());
      } catch(e){}
    }
  });
}

function getUnclaimedCardTransactions() {
  var userInfo = getCachedUserInfo_();
  if (!userInfo.employeeInfo.hasCard) return { status: "success", data: [] };
  
  var data = getSheetData_(SHEET_NAMES.CARD_TRANSACTIONS);
  var myTrans = data.filter(function(row) {
    return String(row['カード会員番号']).trim() === String(userInfo.employeeInfo.cardId).trim() && row['ステータス'] === '未精算';
