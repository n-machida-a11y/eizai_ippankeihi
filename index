        useDate: document.getElementById('M-useDate'),
        amount: document.getElementById('M-amount'),
        payee: document.getElementById('M-payee'),
        remarks: document.getElementById('M-remarks'),
        settlementMethod: document.getElementById('M-settlementMethod'),
        receiptUrl: document.getElementById('M-receiptUrl'),
        isCard: document.getElementById('M-isCard'),
        preTaxAmount: document.getElementById('M-preTaxAmount'),
        areaCode: document.getElementById('M-areaCode'),
        taxDistCode: document.getElementById('M-taxDistCode')
