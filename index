          if(els.useDate) els.useDate.value = ex.useDate ? String(ex.useDate).replace(/\//g, '-') : '';
          if(els.itemCode) els.itemCode.value = ex.itemCode;
          if(els.amount) els.amount.value = ex.amount;
          if(els.payee) els.payee.value = ex.payee || '';
          if(els.remarks) els.remarks.value = ex.remarks || '';
          if(els.settlementMethod) els.settlementMethod.value = ex.settlementMethod || '現金';
          // 領収書: 既存URLがある場合はステータス欄にリンクを表示
          if(ex.receiptUrl) {
            if(els.receiptUrl) els.receiptUrl.value = ex.receiptUrl;
            if(els.uploadStatus) els.uploadStatus.innerHTML =
              '<span class="text-success"><i class="bi bi-check-circle"></i> アップロード済み</span>' +
              ' <a href="' + ex.receiptUrl + '" onclick="window.open(this.href,\'receipt_window\',\'noopener,width=900,height=700\'); return false;" class="receipt-link ms-2">確認する</a>';
          } else {
            if(els.receiptUrl) els.receiptUrl.value = '';
          }
          if(els.transactionId) els.transactionId.value = ex.transactionId;
          if(els.isCard) els.isCard.checked = ex.isCard;
          if(els.preTaxAmount) els.preTaxAmount.value = ex.preTaxAmount || '';
          
          if(els.deleteBtn) els.deleteBtn.style.display = 'block';
          
          if(els.taxDistCode) {
             els.taxDistCode.value = ex.taxDistCode || ''; 
             calculateTaxA({target: els.taxDistCode});
          }
        }
      } else {
        var dateEl = document.getElementById('A-date');
        if(els.useDate && dateEl) els.useDate.value = dateEl.value;
        if(els.settlementMethod) els.settlementMethod.value = '現金';
        if(els.deleteBtn) els.deleteBtn.style.display = 'none';
        
        if(els.taxDistCode) {
           els.taxDistCode.value = '3010'; 
           calculateTaxA({target: els.taxDistCode});
        }
      }
      onItemCodeChangeA(true);
      if(expenseModalInstance) expenseModalInstance.show();
    }

    function addExpenseItemA() {
