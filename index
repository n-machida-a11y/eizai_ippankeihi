  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // グローバル変数（サーバーサイドからの値）
    var EMPLOYEE_INFO = <?!= employeeInfo ?>;
    var IS_MANAGER = <?!= isManager ?>;
    var IS_ACCOUNTING_ADMIN = <?!= isAccountingAdmin ?>;
    var EXPENSE_ITEMS_MASTER = <?!= expenseItems ?>;
    var TRAVEL_RULES_MASTER = <?!= travelRules ?>;
    var AREA_MASTER = <?!= areaMaster ?>;
    var TAX_MASTER = <?!= taxMaster ?>;
    var UNCLAIMED_COUNT = <?!= unclaimedCount ?>;
    var PENDING_COUNT = <?!= pendingCount ?>;
    var EXPENSE_ITEMS_PATTERN_MASTER = <?!= expenseItemPatterns ?>;

    var currentExpenses = [];
    var expenseModalInstance, cardImportModalInstance, adminUploadModalInstance, alertModalInstance;
    var unclaimedCardTransactions = [];
    var viewC_ReturnView = 'view-E-my-reports';
    var isCalculatingTax = false;
    var isEditMode = false;
    var isUploading = false;

    // ステータス設定
    var STATUS_CONFIG = {
      '一時保存':     { badge: 'bg-secondary', row: 'status-row-draft' },
      '差戻し':       { badge: 'bg-danger',    row: 'status-row-rejected' },
      '申請中':       { badge: 'bg-warning text-dark', row: 'status-row-pending' },
      '1次承認待ち':  { badge: 'bg-warning text-dark', row: 'status-row-pending' },
      '2次承認待ち':  { badge: 'bg-info text-dark',    row: 'status-row-pending' },
      '承認済':       { badge: 'bg-success',   row: 'status-row-approved' },
      '精算申請済':   { badge: 'bg-primary',   row: 'status-row-completed' }
    };

    document.addEventListener('DOMContentLoaded', function() {
      try {
        document.getElementById('user-info-display').textContent = EMPLOYEE_INFO.name;
        
        var badgeEl = document.getElementById('approval-count-badge');
        if(IS_MANAGER && badgeEl) {
          badgeEl.textContent = PENDING_COUNT;
        }
        
        if(UNCLAIMED_COUNT > 0) { 
          var alertEl = document.getElementById('unclaimed-alert');
          var countEl = document.getElementById('unclaimed-count-display');
          if(alertEl) alertEl.style.setProperty('display','flex','important'); 
          if(countEl) countEl.textContent = UNCLAIMED_COUNT; 
        }
        
        expenseModalInstance = new bootstrap.Modal(document.getElementById('expenseModal'));
        document.getElementById('expenseModal').addEventListener('hidden.bs.modal', function() {
          isUploading = false;
        });
        cardImportModalInstance = new bootstrap.Modal(document.getElementById('cardImportModal'));
        adminUploadModalInstance = new bootstrap.Modal(document.getElementById('adminUploadModal'));
        alertModalInstance = new bootstrap.Modal(document.getElementById('customAlertModal'));
        
        initSelects();
        buildNav();
        showView('view-A-expense-report');
      } catch(e) {
        console.error('初期化エラー:', e);
      }
    });

    function buildNav(){
      document.querySelectorAll('.nav-link').forEach(function(l) {
        if(!l.onclick) l.addEventListener('click', function(e) { 
          e.preventDefault(); 
          if(l.dataset.view) showView(l.dataset.view); 
        });
      });
    }
    
    // skipDataLoad=true のとき一覧データの再取得をスキップ（パターン3で事前取得済みの場合）
    function showView(id, skipDataLoad) {
      document.querySelectorAll('.app-view').forEach(function(v) { v.classList.remove('active'); });
      var targetView = document.getElementById(id);
      if(targetView) targetView.classList.add('active');

      // 編集モード解除（申請画面以外に遷移時）
      if(id !== 'view-A-expense-report') {
        isEditMode = false;
        var backNav = document.getElementById('A-back-nav');
