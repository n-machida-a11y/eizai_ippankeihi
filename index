      if(id === 'view-A-expense-report') {
        var dateEl = document.getElementById('A-date');
        if(dateEl && !dateEl.value) dateEl.value = new Date().toISOString().split('T')[0];
      }
      if(id === 'view-B-approval-list' && !skipDataLoad) loadPendingReportsB();
      if(id === 'view-E-my-reports' && !skipDataLoad) loadMyReportsE();
    }

