    // 申請時に全明細の必須フィールドを検証する（一時保存はスキップ）
    function validateExpensesForSubmit_() {
      var errors = [];
      for(var i = 0; i < currentExpenses.length; i++) {
        var exp = currentExpenses[i];
        var rowNum = i + 1;
        var masterItem = exp.itemCode ? EXPENSE_ITEMS_MASTER.find(function(m) {
          return String(m['経費項目コード']) === String(exp.itemCode);
        }) : null;
        if(!masterItem) continue;

        if(masterItem['支払先'] === '必須' && !(exp.payee || '').trim()) {
          errors.push(rowNum + '行目: 支払先は必須です');
        }
        if(masterItem['備考'] === '必須' && !(exp.remarks || '').trim()) {
          errors.push(rowNum + '行目: 備考は必須です');
        }

        var receiptRule = masterItem['領収書等'] || '';
        if(receiptRule === '必要' && !exp.receiptUrl) {
          errors.push(rowNum + '行目: この経費項目には領収書が必要です');
        }
        var condMatch = receiptRule.match(/不要（(\d+)万円未満）/);
        if(condMatch && Number(exp.amount) >= Number(condMatch[1]) * 10000 && !exp.receiptUrl) {
          errors.push(rowNum + '行目: ' + condMatch[1] + '万円以上のため領収書が必要です');
        }
      }
      if(errors.length > 0) {
        customAlert(errors.join('\n'));
        return false;
      }
      return true;
    }

