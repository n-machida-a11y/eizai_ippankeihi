    // --- Helper Logic (Tax, Rules) ---
    function calculateTaxA(event) {
      if (isCalculatingTax) return;
      isCalculatingTax = true;
      try {
        var distSelect = document.getElementById('M-taxDistCode');
        var amountEl = document.getElementById('M-amount');
        var preTaxEl = document.getElementById('M-preTaxAmount');
        
        var taxRateEl = document.getElementById('M-calc-taxRate');
        var taxClassEl = document.getElementById('M-calc-taxClass');
        var taxCalcEl = document.getElementById('M-calc-taxCalc');

        var amount = parseFloat(amountEl ? amountEl.value : 0) || 0;
        var selectedCode = distSelect ? distSelect.value : '';
        
        var taxData = TAX_MASTER.find(function(t) { return String(t['消費税区分コード']) === String(selectedCode); });
        
        var rate = 10; // デフォルト
        if (taxData) {
          rate = Number(taxData['消費税率']);
          if(taxRateEl) taxRateEl.value = rate;
          if(taxClassEl) taxClassEl.value = taxData['消費税分類区分'];
          if(taxCalcEl) taxCalcEl.value = taxData['消費税計算区分'];
        } else {
          if(taxRateEl) taxRateEl.value = 10;
          if(taxClassEl) taxClassEl.value = '';
          if(taxCalcEl) taxCalcEl.value = '';
        }

        if (amount > 0 && preTaxEl) {
          preTaxEl.value = Math.floor(amount / (1 + rate/100));
        }
      } catch (e) { console.error(e); }
      isCalculatingTax = false;
    }

    // ① フィールドの表示・必須制御ヘルパー（支払先・精算方法・金額・消費税区分・備考に使用）
    // rule: '必須' | '任意' | '不要'
    function applyFieldRule_(wrapperId, inputEl, rule) {
      var wrapper = document.getElementById(wrapperId);
      if (!wrapper) return;
      var reqMark = wrapper.querySelector('.field-req-mark');
      if (rule === '不要') {
        wrapper.style.display = 'none';
        if (inputEl) {
          inputEl.removeAttribute('required');
          if (inputEl.tagName !== 'SELECT') inputEl.value = '';
        }
        if (reqMark) reqMark.style.display = 'none';
      } else {
        wrapper.style.display = '';
        if (inputEl) {
          if (rule === '必須') {
            inputEl.setAttribute('required', '');
            if (reqMark) reqMark.style.display = '';
          } else {
            inputEl.removeAttribute('required');
            if (reqMark) reqMark.style.display = 'none';
          }
        }
      }
    }

    function onItemCodeChangeA(isInit) {
      var cEl = document.getElementById('M-itemCode');
      var c = cEl ? cEl.value : '';
      var area = document.getElementById('M-area-wrapper');
      var itemCodeWrapper = document.getElementById('M-itemCode-wrapper');
      var showArea = (c === '102');
      if(area) area.style.display = showArea ? '' : 'none';
      if(itemCodeWrapper) {
        // 経費項目は常にcol-md-6（エリアも同幅のため切替不要）
      }

      var transIdEl = document.getElementById('M-transactionId');
      if(!transIdEl || !transIdEl.value) {
        if(c === '101') {
           var rule = getRule();
           if(rule) {
             var amtEl = document.getElementById('M-amount');
             if(amtEl) amtEl.value = rule['日当'];
             calculateTaxA({target:{id:'M-amount'}});
           }
        } else if (c === '102') {
           updateAccommodationLimitA();
        }
      }

      // ① ② ③ 経費項目マスタから情報取得（1回のみ）
      var masterItem = c ? EXPENSE_ITEMS_MASTER.find(function(m) { return String(m['経費項目コード']) === String(c); }) : null;
      var remarksEl = document.getElementById('M-remarks');
      var taxDistEl = document.getElementById('M-taxDistCode');
      var fileUpload = document.getElementById('M-file-upload');

      if(masterItem) {
        // ① 各フィールドの表示・必須制御（経費項目マスタの列を参照）
        applyFieldRule_('M-settlement-wrapper', document.getElementById('M-settlementMethod'), masterItem['精算方法']);
        applyFieldRule_('M-amount-wrapper',     document.getElementById('M-amount'),           masterItem['金額']);
        applyFieldRule_('M-payee-wrapper',      document.getElementById('M-payee'),            masterItem['支払先']);
        applyFieldRule_('M-tax-wrapper',        document.getElementById('M-taxDistCode'),      masterItem['消費税区分']);
        applyFieldRule_('M-remarks-wrapper',    remarksEl,                                     masterItem['備考']);

        // ① 領収書の表示制御（'必要' | '任意' | '不要' | '不要（N万円未満）'）
        var receiptWrapper = document.getElementById('M-receipt-wrapper');
        if(receiptWrapper) {
          if(masterItem['領収書等'] === '不要') {
            // 完全に不要 → 非表示・クリア
            receiptWrapper.style.display = 'none';
            if(fileUpload) fileUpload.value = '';
            var urlEl = document.getElementById('M-receiptUrl');
            if(urlEl) urlEl.value = '';
            var statusEl = document.getElementById('M-upload-status');
            if(statusEl) statusEl.innerHTML = '';
          } else {
            // 必要・任意・条件付き不要 → 表示し、金額に応じた必要性を更新
            receiptWrapper.style.display = '';
          }
        }
        updateReceiptRequirementA();

        // ② 備考欄プレースホルダーを自動設定
        if(remarksEl) {
          var remarksExample = (masterItem['備考例（変更候補）'] || '').trim();
          remarksEl.placeholder = (remarksExample && remarksExample !== '（空欄）' && remarksExample !== '空欄') ? remarksExample : '';
        }

        // ③ 消費税区分デフォルト値を設定（ユーザーが項目を変更したときのみ）
        if(isInit !== true && taxDistEl && EXPENSE_ITEMS_PATTERN_MASTER && EMPLOYEE_INFO) {
          var pattern = EXPENSE_ITEMS_PATTERN_MASTER.find(function(p) {
            return String(p['経費項目コード']) === String(c) && String(p['職種区分']) === String(EMPLOYEE_INFO.jobTypeCode);
          });
          if(pattern && pattern['消費税選択区分コード']) {
            taxDistEl.value = pattern['消費税選択区分コード'];
            calculateTaxA({target: taxDistEl});
          }
        }
      } else {
        // 経費項目未選択・リセット時はすべてデフォルト状態（表示・任意）に戻す
        ['M-settlement-wrapper','M-amount-wrapper','M-payee-wrapper','M-tax-wrapper','M-remarks-wrapper','M-receipt-wrapper'].forEach(function(id) {
          var el = document.getElementById(id);
          if(el) el.style.display = '';
        });
        var payeeInput = document.getElementById('M-payee');
        if(payeeInput) payeeInput.removeAttribute('required');
        var amountInput = document.getElementById('M-amount');
        if(amountInput) amountInput.setAttribute('required', '');
        var taxInput = document.getElementById('M-taxDistCode');
        if(taxInput) taxInput.setAttribute('required', '');
        if(remarksEl) {
          remarksEl.removeAttribute('required');
          remarksEl.placeholder = '例: 会議のため';
        }
        // * マークをデフォルト状態に戻す
        document.querySelectorAll('#expenseModal .field-req-mark').forEach(function(mark) {
          mark.style.display = (mark.dataset.default === 'show') ? '' : 'none';
        });
        updateReceiptRequirementA();
      }
    }
    
    // 金額に応じて領収書の必要性を動的更新（例：乗車券代 '不要（3万円未満）'）
    function updateReceiptRequirementA() {
      var cEl = document.getElementById('M-itemCode');
      var c = cEl ? cEl.value : '';
      var receiptWrapper = document.getElementById('M-receipt-wrapper');
      if(!c || !receiptWrapper || receiptWrapper.style.display === 'none') return;

      var masterItem = EXPENSE_ITEMS_MASTER.find(function(m) { return String(m['経費項目コード']) === String(c); });
      if(!masterItem) return;

      var receiptRule = masterItem['領収書等'] || '';
      var reqMark = receiptWrapper.querySelector('.field-req-mark');

      if(receiptRule === '必要') {
        if(reqMark) reqMark.style.display = '';
      } else {
        // '不要（N万円未満）' パターン：金額がしきい値以上なら必要
        var condMatch = receiptRule.match(/不要（(\d+)万円未満）/);
        if(condMatch) {
          var threshold = Number(condMatch[1]) * 10000;
          var amountEl = document.getElementById('M-amount');
          var amount = amountEl ? (Number(amountEl.value) || 0) : 0;
          var isRequired = (amount >= threshold);
          receiptWrapper.dataset.condRequired = isRequired ? 'true' : 'false';
          if(reqMark) reqMark.style.display = isRequired ? '' : 'none';
        } else {
          if(reqMark) reqMark.style.display = 'none';
        }
      }
    }

    function updateAccommodationLimitA() {
      var transIdEl = document.getElementById('M-transactionId');
      if(transIdEl && transIdEl.value) return;
      var rule = getRule();
      var acEl = document.getElementById('M-areaCode');
      var ac = acEl ? acEl.value : '';
      if(rule && ac) {
        var aRule = AREA_MASTER.find(function(a) { return String(a['地域区分']) === ac; });
        var base = Number(rule['宿泊費']);
        var add = Number(aRule ? aRule['追加宿泊費'] : 0);
        var amtEl = document.getElementById('M-amount');
        if(amtEl) amtEl.value = base + add;
        calculateTaxA({target:{id:'M-amount'}});
      }
    }
    
    function getRule() {
      return TRAVEL_RULES_MASTER.find(function(r) { 
        return String(r['役職']) === String(EMPLOYEE_INFO.positionCode) && String(r['職種区分']) === String(EMPLOYEE_INFO.jobTypeCode); 
      });
    }

    // --- File Upload ---
    function handleFileUploadA(e) {
      var file = e.target.files[0];
      if(!file) return;
      var reader = new FileReader();
      reader.onload = function(evt) {
        var statusEl = document.getElementById('M-upload-status');
        if(statusEl) statusEl.textContent = 'アップロード中...';
        isUploading = true; // ④
        google.script.run.withSuccessHandler(function(r) {
          isUploading = false; // ④
          if(r.status === 'success') {
            var urlEl = document.getElementById('M-receiptUrl');
            if(urlEl) urlEl.value = r.url;
            if(statusEl) statusEl.innerHTML = '<span class="text-success"><i class="bi bi-check-circle"></i> アップロード完了</span>';
          } else {
            customAlert(r.message);
            if(statusEl) statusEl.innerHTML = '<span class="text-danger">エラー</span>';
          }
        }).withFailureHandler(function(err) {
          isUploading = false; // ④
          customAlert('アップロードエラー: ' + (err.message || err));
          if(statusEl) statusEl.innerHTML = '<span class="text-danger">エラー</span>';
        }).uploadBase64Image(evt.target.result, file.name);
      };
      reader.readAsDataURL(file);
    }

    // --- CSV & Card Import ---
    function openAdminUploadModal(){ if(adminUploadModalInstance) adminUploadModalInstance.show(); }
    
    function uploadCardCsv(){
      var fileEl = document.getElementById('admin-csv-file');
      var f = fileEl ? fileEl.files[0] : null;
      if(!f) return;
      var r = new FileReader();
      r.onload = function(e) {
        showLoading(true);
        google.script.run.withSuccessHandler(function(res) {
          showLoading(false); 
          customAlert(res.message); 
          if(adminUploadModalInstance) adminUploadModalInstance.hide();
        }).processCardExcel(e.target.result);
      };
      r.readAsDataURL(f);
    }
    
    function openCardImportModalA() {
      google.script.run.withSuccessHandler(function(res) {
        unclaimedCardTransactions = res.data;
        var tb = document.getElementById('card-import-list-body'); 
        if(!tb) return;
        tb.innerHTML = '';
        if(unclaimedCardTransactions.length === 0) {
          tb.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-3">未精算のカード明細はありません</td></tr>';
        } else {
          unclaimedCardTransactions.forEach(function(t, i) {
            tb.innerHTML += '<tr><td><input type="checkbox" class="card-chk" data-idx="' + i + '"></td><td>' + t.useDate + '</td><td>' + t.description + '</td><td class="text-amount">' + formatAmount(t.amount) + '</td></tr>';
          });
        }
        if(cardImportModalInstance) cardImportModalInstance.show();
      }).getUnclaimedCardTransactions();
    }
    
    function toggleCardImportAll(ck) { 
      document.querySelectorAll('.card-chk').forEach(function(c) { c.checked = ck.checked; }); 
    }
    
    function importSelectedCardTransactions() {
      var chks = document.querySelectorAll('.card-chk:checked');
      chks.forEach(function(c) {
        var t = unclaimedCardTransactions[c.dataset.idx];
        currentExpenses.push({
          expenseId: 'temp_' + Date.now() + Math.random(),
          useDate: t.useDate.split('/').join('-'),
          amount: t.amount,
          remarks: t.description,
          payee: t.storeName || '',
          transactionId: t.transactionId,
          isCard: true,
          settlementMethod: 'クレジットカード(会社カード)', 
          itemCode: '',
          taxDistCode: '3010',
          taxRate: 10,
          taxClass: '30',
          taxCalc: '1',
          preTaxAmount: Math.floor(t.amount / 1.1),
          receiptUrl: ''
        });
      });
      renderExpenseListA();
      if(cardImportModalInstance) cardImportModalInstance.hide();
    }

    // --- Search ---
    function execSearch() {
      showLoading(true);
      var c = {
        startDate: document.getElementById('S-startDate') ? document.getElementById('S-startDate').value : '',
        endDate: document.getElementById('S-endDate') ? document.getElementById('S-endDate').value : '',
        minAmount: document.getElementById('S-minAmount') ? document.getElementById('S-minAmount').value : '',
        maxAmount: document.getElementById('S-maxAmount') ? document.getElementById('S-maxAmount').value : '',
        payee: document.getElementById('S-payee') ? document.getElementById('S-payee').value : ''
      };
      google.script.run.withSuccessHandler(function(res) {
        showLoading(false); 
        renderMyReports(res);
      }).searchReports(c);
    }
    
    function clearSearch() {
      var els = ['S-startDate', 'S-endDate', 'S-minAmount', 'S-maxAmount', 'S-payee'];
      els.forEach(function(id) { 
        var el = document.getElementById(id); 
        if(el) el.value = ''; 
      });
      loadMyReportsE();
    }

    // --- View E/B/C Loaders ---
    function loadMyReportsE() {
      showLoading(true); 
      google.script.run.withSuccessHandler(function(res){
        showLoading(false); 
        renderMyReports(res);
      }).withFailureHandler(function(e){
        showLoading(false);
        customAlert('読み込みエラー: ' + e.message);
      }).getMyReports();
    }
    
    function renderMyReports(reports) {
      var tb = document.getElementById('E-my-reports-list-body'); 
      if(!tb) return;
      tb.innerHTML = '';
      if(!reports || !reports.length) { 
        tb.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4"><i class="bi bi-inbox fs-1 d-block mb-2"></i>申請データがありません</td></tr>'; 
        return; 
      }
      
      var currentStatus = "";
      reports.forEach(function(r) {
        if(r['承認ステータス'] !== currentStatus) {
          currentStatus = r['承認ステータス'];
          tb.innerHTML += '<tr class="status-group-header"><td colspan="6">' + currentStatus + '</td></tr>';
        }
        
        var det = r.details.map(function(d) {
          var receiptIcon = d.receiptUrl ? ' <a href="' + d.receiptUrl + '" onclick="window.open(this.href, \'receipt_window\', \'noopener,width=900,height=700\'); return false;" class="receipt-link" title="領収書"><i class="bi bi-paperclip"></i></a>' : '';
          return d.useDate + ' ' + d.itemName + ' (' + formatAmount(d.amount) + ')' + receiptIcon;
        }).join('<br>');
        
        var btn = '';
        if(['一時保存','差戻し'].indexOf(r['承認ステータス']) > -1) {
          btn = '<button class="btn btn-sm btn-outline-primary" onclick="editReport(\'' + r['経費ID'] + '\')"><i class="bi bi-pencil"></i> 編集</button>';
          btn += ' <button class="btn btn-sm btn-outline-danger" onclick="deleteReportE(\'' + r['経費ID'] + '\')"><i class="bi bi-trash"></i> 削除</button>';
        } else {
          btn = '<button class="btn btn-sm btn-outline-secondary" onclick="showDetail(\'' + r['経費ID'] + '\')"><i class="bi bi-eye"></i> 詳細</button>';
        }
        
        var rowClass = getStatusRowClass(r['承認ステータス']);
        tb.innerHTML += '<tr class="' + rowClass + '"><td>' + r['日付'] + '</td><td>' + getStatusBadge(r['承認ステータス']) + '</td><td>' + r['件名'] + '</td><td class="text-amount">' + r['formattedTotal'] + '</td><td><small>' + det + '</small></td><td>' + btn + '</td></tr>';
      });
    }
    
    function deleteReportE(rid) {
      if(!confirm('この申請（一時保存）を完全に削除しますか？\n※紐付いていたカード明細は未精算に戻ります。')) return;
      showLoading(true);
      google.script.run.withSuccessHandler(function(r) {
        showLoading(false);
        if(r.status === 'success') { customAlert(r.message); loadMyReportsE(); }
        else { customAlert(r.message); }
      }).deleteReport(rid);
    }
    
    function editReport(id) {
      showLoading(true); 
      google.script.run.withSuccessHandler(function(r) {
        showLoading(false); 
        if(r.status === 'error'){ customAlert(r.message); return; }
        resetFormA();
        var h = r.data.header;
        var reportIdEl = document.getElementById('A-reportId');
        var dateEl = document.getElementById('A-date');
        var titleEl = document.getElementById('A-title');
        var remarksEl = document.getElementById('A-remarks');
        var provEl = document.getElementById('A-provisional');
        var backNav = document.getElementById('A-back-nav');
        
        if(reportIdEl) reportIdEl.value = h['経費ID'];
        if(dateEl) dateEl.value = h['日付'].replace(/\//g,'-');
        if(titleEl) titleEl.value = h['件名'];
        if(remarksEl) remarksEl.value = h['備考'];
        if(provEl) provEl.value = h['仮払金'] || 0; 
        currentExpenses = r.data.expenses;
        
        isEditMode = true;
        if(backNav) backNav.style.display = 'block';
        
        renderExpenseListA();
        showView('view-A-expense-report');
      }).withFailureHandler(function(e){
        showLoading(false);
        customAlert('編集データ読み込みエラー: ' + e.message);
      }).getReportDataForEdit(id);
    }

    function showDetail(id) {
      var activeView = document.querySelector('.app-view.active');
      viewC_ReturnView = activeView ? activeView.id : 'view-E-my-reports';
      
      showLoading(true); 
      google.script.run.withSuccessHandler(function(d) {
        showLoading(false); 
        var h = d.header;
        var dateEl = document.getElementById('C-header-date');
        if(dateEl) dateEl.textContent = h['日付'];
        
        var statusBadge = document.getElementById('C-header-status-badge');
        if(statusBadge) {
          var cfg = STATUS_CONFIG[h['承認ステータス']] || { badge: 'bg-secondary' };
          statusBadge.className = 'badge fs-6 ' + cfg.badge;
          statusBadge.innerHTML = h['承認ステータス'];
        }
        
        var applicantEl = document.getElementById('C-header-applicant');
        var titleEl = document.getElementById('C-header-title');
        var remarksEl = document.getElementById('C-header-remarks');
        if(applicantEl) applicantEl.textContent = h['申請者'];
        if(titleEl) titleEl.textContent = h['件名'];
        if(remarksEl) remarksEl.textContent = h['備考'] || '-';
        
        var tot = Number(h['合計経費']);
        var prov = Number(h['仮払金'] || 0);
        var totalEl = document.getElementById('C-header-total');
        var provEl = document.getElementById('C-header-prov');
        var reimbEl = document.getElementById('C-header-reimb');
        if(totalEl) totalEl.textContent = formatAmount(tot);
        if(provEl) provEl.textContent = formatAmount(prov);
        if(reimbEl) reimbEl.textContent = formatAmount(tot - prov);

        var tb = document.getElementById('C-expenses-body'); 
        if(tb) {
          tb.innerHTML = '';
          d.expenses.forEach(function(e) {
            var receiptLink = e.receiptUrl ? '<a href="' + e.receiptUrl + '" onclick="window.open(this.href, \'receipt_window\', \'noopener,width=900,height=700\'); return false;" class="receipt-link" title="領収書を開く"><i class="bi bi-paperclip"></i></a>' : '-';
            tb.innerHTML += '<tr><td>' + e.useDate + '</td><td>' + e.itemName + '</td><td class="text-amount">' + formatAmount(e.amount) + '</td><td>' + (e.payee || '-') + '</td><td>' + (e.settlementMethod || '-') + '</td><td><small>' + (e.remarks || '-') + '</small></td><td>' + receiptLink + '</td></tr>';
          });
        }
        
        var rejDiv = document.getElementById('C-rejection-reason');
        if(rejDiv) {
          if(h['差戻し理由']) {
            rejDiv.innerHTML = '<strong><i class="bi bi-exclamation-triangle"></i> 差戻し理由:</strong> ' + h['差戻し理由'];
            rejDiv.style.display = 'block';
          } else {
            rejDiv.style.display = 'none';
          }
        }
        
        var div = document.getElementById('C-approval-buttons');
        if(div) div.style.display = (viewC_ReturnView === 'view-B-approval-list') ? 'block' : 'none';
        var reportIdEl = document.getElementById('C-reportId');
        if(reportIdEl) reportIdEl.value = id;
        
        showView('view-C-report-detail');
      }).withFailureHandler(function(e){
        showLoading(false);
        customAlert('詳細読み込みエラー: ' + e.message);
      }).getReportDetails(id);
    }
    
    var backBtn = document.getElementById('C-back-button');
    if(backBtn) backBtn.onclick = function(){ showView(viewC_ReturnView); };

    function loadPendingReportsB() {
      showLoading(true);
      google.script.run.withSuccessHandler(function(list) {
        showLoading(false);
        renderPendingListB_(list);
      }).withFailureHandler(function(e){
        showLoading(false);
        customAlert('読み込みエラー: ' + e.message);
      }).getPendingReports();
    }

    // パターン3: 承認/差戻し結果に含まれるリストを直接描画（サーバー再コール不要）
    function renderPendingListB_(list) {
      var d = document.getElementById('B-approval-list-body');
      if(!d) return;
      d.innerHTML = '';
      if(!list || !list.length) {
        d.innerHTML = '<tr><td colspan="8" class="text-center text-muted py-4"><i class="bi bi-check-circle fs-1 d-block mb-2"></i>承認待ちの申請はありません</td></tr>';
      } else {
        list.forEach(function(r) {
          var statusCfg = STATUS_CONFIG[r['承認ステータス']] || { badge: 'bg-secondary' };
          var badgeHtml = '<span class="badge ' + statusCfg.badge + '">' + r['承認ステータス'] + '</span>';

          var total = r['合計経費'] || 0;
          var prov = r['仮払金'] || 0;
          var reimb = r['差引精算額'];
          if (reimb === undefined || reimb === "") {
            reimb = Number(total) - Number(prov);
          }

          var tr = document.createElement('tr');
          tr.innerHTML =
            '<td>' + r['日付'] + '</td>' +
            '<td>' + r['申請者'] + '</td>' +
            '<td>' + r['件名'] + '</td>' +
            '<td class="text-amount">' + formatAmount(total) + '</td>' +
            '<td class="text-amount">' + formatAmount(prov) + '</td>' +
            '<td class="text-amount fw-bold">' + formatAmount(reimb) + '</td>' +
            '<td>' + badgeHtml + '</td>' +
            '<td><button class="btn btn-sm btn-outline-primary" onclick="showDetail(\'' + r['経費ID'] + '\');viewC_ReturnView=\'view-B-approval-list\';">確認</button></td>';

          d.appendChild(tr);
        });
      }
    }
    
    function handleApproveC() {
      if(!confirm('承認しますか？')) return;
      showLoading(true);
      var reportIdEl = document.getElementById('C-reportId');
      var reportId = reportIdEl ? reportIdEl.value : '';
      google.script.run.withSuccessHandler(function(r) {
        showLoading(false);
        customAlert(r.message);
        // パターン3: 承認結果に承認待ちリストが含まれる場合は再取得しない
        if (r.pendingList) {
          renderPendingListB_(r.pendingList);
          showView('view-B-approval-list', true);
        } else {
          showView('view-B-approval-list');
        }
      }).approveReport(reportId);
    }

    function handleRejectC() {
      var reason = prompt('差戻し理由を入力してください');
      if(reason === null) return; // キャンセル
      if(!reason.trim()) { customAlert('差戻し理由を入力してください'); return; }
      showLoading(true);
      var reportIdEl = document.getElementById('C-reportId');
      var reportId = reportIdEl ? reportIdEl.value : '';
      google.script.run.withSuccessHandler(function(res) {
        showLoading(false);
        customAlert(res.message);
        // パターン3: 差戻し結果に承認待ちリストが含まれる場合は再取得しない
        if (res.pendingList) {
          renderPendingListB_(res.pendingList);
          showView('view-B-approval-list', true);
        } else {
          showView('view-B-approval-list');
        }
      }).rejectReport(reportId, reason);
    }

    function showLoading(b) { 
      var overlay = document.getElementById('loading-overlay');
      if(overlay) overlay.style.display = b ? 'flex' : 'none';
      document.querySelectorAll('.action-btn').forEach(function(btn) {
        btn.disabled = b;
      });
    }
    
    function customAlert(m) { 
      var msgEl = document.getElementById('customAlertMessage');
      if(msgEl) msgEl.textContent = m; 
      if(alertModalInstance) alertModalInstance.show(); 
    }
  </script>
</body>
</html>
