    function renderExpenseListA() {
      var tb = document.getElementById('A-expense-list-body');
      if(!tb) return;
      var tot = 0;
      tb.innerHTML = '';
      currentExpenses.forEach(function(e) {
        var tr = document.createElement('tr');
        var matchItem = EXPENSE_ITEMS_MASTER.find(function(m) { return String(m['経費項目コード']) === String(e.itemCode); });
        var iName = (matchItem ? matchItem['経費項目'] : null) || e.itemCode || '(未選択)';
        var linkHtml = e.receiptUrl ? '<a href="' + e.receiptUrl + '" onclick="window.open(this.href, \'receipt_window\', \'noopener,width=900,height=700\'); return false;" class="receipt-link" title="領収書を開く"><i class="bi bi-paperclip"></i></a>' : '-';
        tr.innerHTML = 
          '<td>' + (e.useDate || '') + '</td>' +
          '<td>' + iName + '</td>' +
          '<td class="text-amount">' + formatAmount(e.amount) + '</td>' +
          '<td>' + (e.payee || '') + (e.isCard ? ' <span class="badge bg-secondary">Card</span>' : '') + '</td>' +
          '<td>' + (e.settlementMethod || '') + '</td>' +
          '<td>' + (e.remarks || '') + '</td>' +
          '<td>' + linkHtml + '</td>' +
          '<td>' +
            '<button class="btn btn-sm btn-light" onclick="openExpenseModalA(\'' + e.expenseId + '\')">編集</button>' +
            '<button class="btn btn-sm btn-outline-danger ms-1" onclick="deleteExpenseItemDirect(\'' + e.expenseId + '\')">削除</button>' +
          '</td>';
        tb.appendChild(tr);
        tot += Number(e.amount) || 0;
      });
      var totalEl = document.getElementById('A-total-display');
      if(totalEl) totalEl.textContent = formatAmount(tot);
      updateTotalDisplayA();
    }

    function updateTotalDisplayA() {
      var totalEl = document.getElementById('A-total-display');
      var provEl = document.getElementById('A-provisional');
      var provDisplayEl = document.getElementById('A-provisional-display');
      var reimbEl = document.getElementById('A-reimbursement-display');
      
      var tot = totalEl ? Number(totalEl.textContent.replace(/,/g,'')) || 0 : 0;
      var prov = provEl ? Number(provEl.value) || 0 : 0;
      if(provDisplayEl) provDisplayEl.textContent = formatAmount(prov);
      if(reimbEl) reimbEl.textContent = formatAmount(tot - prov);
