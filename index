      var itemCode = document.getElementById('M-itemCode');
      var method = document.getElementById('M-settlementMethod');
      var amt = document.getElementById('M-amount');
      var distSelect = document.getElementById('M-taxDistCode');

      // 非表示フィールドはスキップ、required属性が付いている場合は必須チェック
      function isWrapperVisible_(id) {
        var el = document.getElementById(id);
        return !el || el.style.display !== 'none';
      }

      if(isWrapperVisible_('M-amount-wrapper')) {
        if(!amt || !amt.value) { customAlert('金額は必須です'); return; }
      }
      if(!itemCode || !itemCode.value) { customAlert('経費項目は必須です'); return; }
      if(isWrapperVisible_('M-settlement-wrapper')) {
        if(!method || !method.value) { customAlert('精算方法は必須です'); return; }
      }
      if(isWrapperVisible_('M-tax-wrapper')) {
        if(!distSelect || !distSelect.value) { customAlert('消費税区分は必須です'); return; }
      }
      // 支払先・備考・領収書は申請時にチェック（登録ボタンでは * 表示のみ・エラーなし）

      var eidEl = document.getElementById('M-expenseId');
      var eid = eidEl ? eidEl.value : '';
      
      var taxRateEl = document.getElementById('M-calc-taxRate');
      var taxClassEl = document.getElementById('M-calc-taxClass');
      var taxCalcEl = document.getElementById('M-calc-taxCalc');
      
      var ex = {
        expenseId: eid || ('temp_' + Date.now()),
        useDate: document.getElementById('M-useDate') ? document.getElementById('M-useDate').value : '',
        itemCode: itemCode.value,
        amount: amt.value,
        payee: document.getElementById('M-payee') ? document.getElementById('M-payee').value : '',
        settlementMethod: method.value,
        remarks: document.getElementById('M-remarks') ? document.getElementById('M-remarks').value : '',
        receiptUrl: document.getElementById('M-receiptUrl') ? document.getElementById('M-receiptUrl').value : '',
        isCard: document.getElementById('M-isCard') ? document.getElementById('M-isCard').checked : false,
        transactionId: document.getElementById('M-transactionId') ? document.getElementById('M-transactionId').value : '',
        areaCode: document.getElementById('M-areaCode') ? document.getElementById('M-areaCode').value : '',
        preTaxAmount: document.getElementById('M-preTaxAmount') ? document.getElementById('M-preTaxAmount').value : '',
        taxDistCode: distSelect.value,
        taxRate: taxRateEl ? Number(taxRateEl.value) : 10,
        taxClass: taxClassEl ? taxClassEl.value : '',
        taxCalc: taxCalcEl ? taxCalcEl.value : ''
      };
      
      if(eid) {
